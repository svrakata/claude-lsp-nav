#!/usr/bin/env bash
# lsp-find — locate a TypeScript symbol's declaration as LSP-ready coords.
# Usage:   lsp-find <symbol> [path]
# Output:  <file> line=<N> character=<N>
#
# Copy the file/line/character straight into LSP tool args.
# Searches declaration sites first (function/const/class/interface/type/enum),
# skips imports and re-exports, falls back to first reference otherwise.

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: lsp-find <symbol> [path]" >&2
  exit 2
fi

symbol="$1"
path="${2:-src/}"

# Match declaration sites: function/const/class/interface/type/let/var/enum,
# optionally preceded by export and/or async.
decl_pattern="\b(export\s+)?(async\s+)?(function|const|class|interface|type|let|var|enum)\s+${symbol}\b"

# Find declarations, then drop lines that look like imports or re-exports
# (`from "..."`/`from '...'` is the giveaway).
hit=$(
  rg -n --column --pcre2 "$decl_pattern" "$path" 2>/dev/null \
    | rg -v "from\s+['\"]" \
    | head -1 \
    || true
)

if [ -z "$hit" ]; then
  # Fallback: first occurrence anywhere (may be an import).
  hit=$(rg -n --column --pcre2 "\b${symbol}\b" "$path" 2>/dev/null | head -1 || true)
fi

if [ -z "$hit" ]; then
  echo "lsp-find: '$symbol' not found in $path" >&2
  exit 1
fi

# rg --column emits: file:line:column:matched_text
file=$(echo "$hit" | awk -F: '{print $1}')
line=$(echo "$hit" | awk -F: '{print $2}')

# Bump character to point at the identifier itself, not the leading keyword.
# grep -bo gives 0-based byte offset of the match on that line; LSP wants 1-based.
actual_col=$(sed -n "${line}p" "$file" | grep -bo "\b${symbol}\b" | head -1 | cut -d: -f1 || true)
if [ -n "$actual_col" ]; then
  char=$((actual_col + 1))
else
  char=$(echo "$hit" | awk -F: '{print $3}')
fi

echo "${file} line=${line} character=${char}"
